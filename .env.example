# FraudGraph — copy to .env and fill in your values
# Usage: cp .env.example .env

# Anthropic API key for the AI investigation agent.
# Optional — the demo runs in deterministic fallback mode without it.
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL
FG_POSTGRES_HOST=localhost
FG_POSTGRES_PORT=5432
FG_POSTGRES_USER=fraudgraph
FG_POSTGRES_PASSWORD=fraudgraph
FG_POSTGRES_DB=fraudgraph

# Neo4j
FG_NEO4J_URI=bolt://localhost:7687
FG_NEO4J_USER=neo4j
FG_NEO4J_PASSWORD=fraudgraph

# Redis
FG_REDIS_URL=redis://localhost:6379/0
